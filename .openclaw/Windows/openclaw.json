              "cacheWrite": 0
            },
            "contextWindow": 32768,
            "maxTokens": 4096
          },
          {
            "id": "kimi-k2.5:cloud",
            "name": "Kimi K2.5 Cloud",
            "api": "ollama",
            "reasoning": false,
            "input": [
              "text",
              "image"
            ],
            "cost": {
              "input": 0.5,
              "output": 1.5,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 262144,
            "maxTokens": 8192
          }
        ]
      },
      "lmstudio": {
        "baseUrl": "http://192.168.178.20:1234/v1",
        "apiKey": "lmstudio",
        "api": "openai-completions",
        "models": [
          {
            "id": "deepseek/deepseek-r1-0528-qwen3-8b",
            "name": "Deepseek R1",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 32768,
            "maxTokens": 4096
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "google/gemini-3-flash",
        "fallbacks": [
          "moonshot/kimi-k2.5",
        ]
      },
      "models": {
        "anthropic/claude-opus-4-5": {
          "alias": "opus",
          "params": {
            "cacheControlTtl": "1h",
            "cacheRetention": "short"
          }
        },
        "anthropic/claude-sonnet-4-5": {
          "alias": "sonnet",
          "params": {
            "cacheControlTtl": "1h",
            "cacheRetention": "short"
          }
        },
        "google/gemini-3-flash": {
          "alias": "gemini"
        },
        "moonshot/kimi-k2.5": {
          "alias": "kimi"
        },
        "xai/grok-4-1-fast": {
          "alias": "grokfast"
        },
        "ollama/kimi-k2.5:cloud": {
          "alias": "kimicloud"
        },
        "ollama/qwen3:8b-q4_k_m": {
          "alias": "qwen3"
        },
        "lmstudio/deepseek/deepseek-r1-0528-qwen3-8b": {
          "alias": "deepseek-r1"
        }
      },
      "workspace": "D:/Apps/OpenClaw/workspace",
      "bootstrapMaxChars": 50000,
      "userTimezone": "Europe/Berlin",
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "1h"
      },
      "compaction": {
        "mode": "default",
        "reserveTokensFloor": 10000,
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 40000,
          "prompt": "Update memory/YYYY-MM-DD.md with decisions, confirmed findings, open questions, key constraints, hypotheses, and next steps. Max 400 tokens. Reply NO_REPLY if nothing new.",
          "systemPrompt": "Context getting large. Persist durable research state now."
        }
      },
      "thinkingDefault": "low",
      "heartbeat": {
        "every": "30m",
        "activeHours": {
          "start": "00:00",
          "end": "24:00",
          "timezone": "Europe/Berlin"
        },
        "model": "moonshot/kimi-k2.5",
        "includeReasoning": false,
        "target": "telegram",
        "to": "000000000",
        "accountId": "example_bot",
        "prompt": "Read HEARTBEAT.md if it exists (workspace context). Follow it strictly. Do not infer or repeat old tasks from prior chats. If nothing needs attention, reply HEARTBEAT_OK.",
        "ackMaxChars": 300
      },
      "maxConcurrent": 1,
      "subagents": {
        "maxConcurrent": 2
      },
      "sandbox": {
        "browser": {
          "allowHostControl": true
        }
      }
    },
    "list": [
      {
        "id": "main",
        "model": "google/gemini-3-flash",
        "identity": {
          "name": "Bot",
          "theme": "neutral digital assistant",
          "emoji": "🤖"
        }
      }
    ]
  },
  "tools": {
    "web": {
      "search": {
        "apiKey": "${BRAVE_API_KEY}"
      }
    },
    "media": {
      "image": {
        "enabled": true,
        "maxBytes": 20971520,
        "timeoutSeconds": 120,
        "attachments": {
          "mode": "first",
          "maxAttachments": 1,
          "prefer": "path"
        },
        "models": [
          {
            "provider": "google",
            "model": "gemini-3-flash"
          }
        ]
      },
      "audio": {
        "enabled": true,
        "maxBytes": 20971520,
        "timeoutSeconds": 120,
        "attachments": {
          "mode": "first",
          "maxAttachments": 1,
          "prefer": "path"
        },
        "models": [
          {
            "provider": "google",
            "model": "gemini-3-flash"
          }
        ]
      },
      "video": {
        "enabled": true,
        "maxBytes": 52428800,
        "timeoutSeconds": 240,
        "attachments": {
          "mode": "first",
          "maxAttachments": 1,
          "prefer": "path"
        },
        "models": [
          {
            "provider": "google",
            "model": "gemini-3-flash"
          }
        ]
      }
    },
    "elevated": {
      "enabled": true,
      "allowFrom": {
        "telegram": [
          "000000000"
        ],
        "webchat": [
          "*"
        ]
      }
    },
    "exec": {
      "security": "full",
      "ask": "off"
    }
  },
  "messages": {
    "groupChat": {
      "mentionPatterns": [
        "@example_bot",
        "bot",
        "@bot"
      ],
      "historyLimit": 50
    },
    "queue": {
      "mode": "collect",
      "byChannel": {
        "whatsapp": "collect",
        "telegram": "collect"
      },
      "debounceMs": 3000,
      "cap": 20,
      "drop": "summarize"
    },
    "ackReactionScope": "all",
    "suppressToolErrors": true,
    "tts": {
      "auto": "tagged",
      "provider": "edge",
      "edge": {
        "voice": "de-DE-KatjaNeural",
        "lang": "de-DE",
        "outputFormat": "mp3"
      },
      "maxTextLength": 4000
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "text": true,
    "bash": true,
    "config": true,
    "debug": true,
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "scope": "per-sender",
    "dmScope": "per-channel-peer",
    "resetTriggers": [
      "/reset",
      "/new"
    ],
    "reset": {
      "mode": "daily",
      "atHour": 4,
      "idleMinutes": 120
    },
    "typingIntervalSeconds": 5,
    "maintenance": {
      "mode": "warn",
      "pruneAfter": "30d",
      "maxEntries": 500,
      "rotateBytes": "10mb"
    }
  },
  "cron": {
    "enabled": true,
    "maxConcurrentRuns": 1,
    "sessionRetention": "24h"
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "session-memory": {
          "enabled": true
        }
      }
    }
  },
  "channels": {
    "whatsapp": {
      "dmPolicy": "allowlist",
      "selfChatMode": true,
      "allowFrom": [
        "+4900000000000"
      ],
      "groupPolicy": "allowlist",
      "ackReaction": {
        "emoji": "👀",
        "direct": true,
        "group": "mentions"
      },
      "debounceMs": 3000,
      "mediaMaxMb": 50
    },
    "telegram": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "replyToMode": "off",
      "groups": {
        "-1000000000000": {
          "requireMention": true,
          "enabled": true,
          "allowFrom": [
            "*"
          ]
        },
        "-1000000000001": {
          "requireMention": true,
          "enabled": true,
          "allowFrom": [
            "*"
          ]
        }
      },
      "allowFrom": [
        "000000000"
      ],
      "groupPolicy": "allowlist",
      "historyLimit": 20,
      "dmHistoryLimit": 20,
      "chunkMode": "newline",
      "streaming": "off",
      "mediaMaxMb": 50,
      "actions": {
        "deleteMessage": false,
        "sendMessage": true,
        "reactions": true,
        "sticker": true
      },
      "reactionNotifications": "all",
      "reactionLevel": "extensive",
      "ackReaction": "👀"
    }
  },
  "discovery": {
    "mdns": {
      "mode": "off"
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "enabled": true,
      "allowedOrigins": [
        "http://127.0.0.1:18789",
        "http://localhost:18789",
        "http://192.168.178.20:18789"
      ],
      "dangerouslyAllowHostHeaderOriginFallback": true,
      "allowInsecureAuth": true,
      "dangerouslyDisableDeviceAuth": true
    },
    "auth": {
      "mode": "token",
      "token": "${REMOTE_TOKEN}"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "remote": {
      "token": "${REMOTE_TOKEN}"
    },
    "tls": {
      "enabled": false,
      "certPath": "D:/Apps/OpenClaw/cert.pem",
      "keyPath": "D:/Apps/OpenClaw/key.pem"
    },
    "nodes": {
      "allowCommands": [],
      "denyCommands": []
    }
  },
  "skills": {
    "install": {
      "nodeManager": "pnpm"
    },
    "entries": {
      "openai-whisper-api": {
        "apiKey": "${OPENAI_API_KEY}"
      },
      "openai-image-gen": {
        "apiKey": "${OPENAI_API_KEY}"
      },
      "bird": {},
      "clawhub": {},
      "gemini": {
        "apiKey": "${GEMINI_API_KEY}"
      }
    }
  },
  "plugins": {
    "entries": {
      "openclaw-web-search": {
        "enabled": true
      },
      "telegram": {
        "enabled": true
      },
      "whatsapp": {
        "enabled": false
      }
    }
  }
}
