{
  "meta": {
    "lastTouchedVersion": "2026.3.1",
    "lastTouchedAt": ""
  },
  "env": {
    "shellEnv": {
      "enabled": true
    },
    "vars": {}
  },
  "wizard": {
    "lastRunAt": "",
    "lastRunVersion": "2026.3.1",
    "lastRunCommand": "onboard",
    "lastRunMode": "local"
  },
  "logging": {
    "level": "error",
    "file": "D:/Apps/OpenClaw/openclaw.log",
    "consoleLevel": "error",
    "consoleStyle": "pretty",
    "redactSensitive": "tools",
    "redactPatterns": [
      "\\bTOKEN\\b\\s*[=:]\\s*([\"']?)([^\\s\"']+)\\1"
    ]
  },
  "browser": {
    "enabled": true,
    "remoteCdpTimeoutMs": 2000,
    "remoteCdpHandshakeTimeoutMs": 4000,
    "executablePath": "",
    "headless": true,
    "noSandbox": true,
    "attachOnly": true,
    "defaultProfile": "remote",
    "profiles": {
      "openclaw": {
        "cdpPort": 18800,
        "color": "#AA0000"
      },
      "remote": {
        "cdpUrl": "http://192.168.178.20:18800",
        "color": "#00AA00"
      },
      "browserless": {
        "cdpUrl": "https://production-sfo.browserless.io?token=${BROWSERLESS_TOKEN}",
        "color": "#0000AA"
      }
    }
  },
  "ui": {
    "assistant": {
      "name": "Bot",
      "avatar": "avatars/Bot.jpg"
    }
  },
  "auth": {
    "profiles": {
      "moonshot:default": {
        "provider": "moonshot",
        "mode": "api_key"
      },
      "google:default": {
        "provider": "google",
        "mode": "api_key"
      },
      "xai:default": {
        "provider": "xai",
        "mode": "api_key"
      },
      "anthropic:default": {
        "provider": "anthropic",
        "mode": "api_key"
      },
      "ollama:default": {
        "provider": "ollama",
        "mode": "api_key"
      },
      "lmstudio:default": {
        "provider": "lmstudio",
        "mode": "api_key"
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "moonshot": {
        "baseUrl": "https://api.moonshot.ai/v1",
        "apiKey": "${MOONSHOT_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "kimi-k2.5",
            "name": "Kimi K2.5",
            "api": "openai-completions",
            "reasoning": false,
            "input": [
              "text",
              "image"
            ],
            "cost": {
              "input": 0.1,
              "output": 0.6,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 262144,
            "maxTokens": 8192
          }
        ]
      },
      "xai": {
        "baseUrl": "https://api.x.ai/v1",
        "apiKey": "${XAI_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "grok-4-1-fast",
            "name": "Grok 4.1 Fast",
            "api": "openai-completions",
            "reasoning": false,
            "input": [
              "text",
              "image"
            ],
            "cost": {
              "input": 0.15,
              "output": 0.6,
              "cacheRead": 0.2,
              "cacheWrite": 0
            },
            "contextWindow": 131072,
            "maxTokens": 4096
          }
        ]
      },
      "google": {
        "baseUrl": "https://generativelanguage.googleapis.com/v1beta",
        "apiKey": "${GEMINI_API_KEY}",
        "api": "google-generative-ai",
        "models": [
          {
            "id": "gemini-3-flash",
